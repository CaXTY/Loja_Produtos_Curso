@using LojaProdutosCurso.Dto.Login
@model LoginUsuarioDto

@* Layout for the login page *@
@{
    Layout = "_LayoutDeslogada";
}

<div class="container">

    <form asp-controller="Login" asp-action="Login" method="post">

        <div class="mb-3">
            <label asp-for="Email"></label>
            <input type="email" asp-for="Email" class="form-control" />
        </div>

        <div class="mb-3">
            <label asp-for="Senha"></label>
            <input type="password" asp-for="Senha" class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">Entrar</button>

    </form>

</div>